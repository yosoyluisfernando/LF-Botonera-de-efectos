# ══════════════════════════════════════════════════════════════════
# LF Botonera — al repositorio va SOLO el código fuente.
# Nada de binarios, cachés, configuraciones personales ni datos del
# usuario (la configuración de la app vive en %APPDATA%, fuera del repo).
# ══════════════════════════════════════════════════════════════════

# ── Binarios e instaladores compilados ──
Compilados/

# ── Respaldo del prototipo Electron (no forma parte del proyecto publicado) ──
Respaldo_Electron/

# ── Dependencias JS ──
node_modules/

# ── Salidas de build ──
# Vite → src/dist/   |   Cargo → src-tauri/target/   (este último lo cubre src-tauri/.gitignore)
dist/
dist-ssr/
src/dist/

# ── Rust/Tauri (cubiertos también por src-tauri/.gitignore) ──
src-tauri/target/
src-tauri/gen/schemas/

# ── Configuración personal de editores ──
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs y temporales ──
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp

# ── Datos del usuario exportados (no son código) ──
*.bdelf
*.bdeplf

# ── Sistema operativo ──
.DS_Store
Thumbs.db
desktop.ini

# ── Archivos locales de trabajo (no van al repositorio) ──
Iniciar_Dev.bat
SUBIR_A_GITHUB.bat
BORRAR_RESPALDO_DE_GITHUB.bat
Resumen.md
*.local
