{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LF Botonera de Efectos",
  "version": "1.0.3",
  "identifier": "com.luis-fernando.botonera",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../src/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LF Botonera de Efectos",
        "width": 1000,
        "height": 700,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": { "depends": ["libwebkit2gtk-4.1-0", "libssl3"] },
      "appimage": { "bundleMediaFramework": true }
    },
    "shortDescription": "Soundboard for radio broadcasters",
    "longDescription": "LF Botonera de Efectos — a Tauri/Rust soundboard for radio stations and live streaming. Supports unlimited profiles, tabs, keyboard shortcuts, dynamic voice-overs and weather announcements. Compatible with LF Automatizador file formats."
  }
}
